#!/usr/bin/env python3
"""daifupdown - switch Ubuntu-ish systems from netplan/networkd/NM towards ifupdown.

This is intentionally conservative.

Ubuntu's default network stack is usually:
- netplan YAML in /etc/netplan/*.yaml
- renderer: systemd-networkd or NetworkManager
- DNS: systemd-resolved (often via /etc/resolv.conf -> stub-resolv.conf)

If you want the old-school /etc/network/interfaces style, the safest approach is:
- generate an interfaces file
- disable netplan configuration (move YAML aside)
- ensure only ONE manager is "owning" each interface at boot

This tool helps you:
- inspect what's managing what
- generate /etc/network/interfaces stanzas from the live system
- create a "plan" + rollback notes
- optionally apply changes (with big warnings)

WARNING:
- Run from a local console (or have out-of-band access).
- Expect to reboot.
- This tool cannot guarantee you won't lose connectivity; it can only reduce surprises.
"""

from __future__ import annotations

import argparse
import datetime as _dt
import os
import pathlib
import re
import sys
from typing import Iterable, List, Tuple

from dumbasslib import (
    confirm_two_tier_or_exit,
    die,
    info,
    require_root,
    run,
)


SKIP_IFACE_PREFIXES = (
    "lo",
    "docker",
    "br-",
    "veth",
    "virbr",
    "vmnet",
    "tun",
    "tap",
    "wg",
)


def _sh(cmd: list[str]) -> str:
    rr = run(cmd, capture=True, check=False)
    return (rr.stdout or rr.stderr).strip()


def _systemctl_active(unit: str) -> str:
    rr = run(["systemctl", "is-active", unit], capture=True, check=False)
    out = rr.stdout.strip()
    return out or f"rc={rr.returncode}"


def _list_netplan_yaml() -> List[str]:
    p = pathlib.Path("/etc/netplan")
    if not p.exists():
        return []
    return sorted(str(x) for x in p.glob("*.yaml"))


def _iface_candidates() -> List[str]:
    # Use `ip -br link` for stable parsing.
    rr = run(["ip", "-br", "link"], capture=True, check=False)
    if rr.returncode != 0:
        die("iproute2 not found or ip failed")
    ifaces: List[str] = []
    for line in rr.stdout.splitlines():
        line = line.strip()
        if not line:
            continue
        name = line.split()[0]
        if name.startswith(SKIP_IFACE_PREFIXES):
            continue
        # Skip obvious container junk
        if any(name.startswith(p) for p in SKIP_IFACE_PREFIXES):
            continue
        ifaces.append(name)
    return ifaces


def _guess_iface_method(iface: str) -> str:
    # Heuristic: if it has a global IPv4 and it's marked dynamic, assume DHCP.
    rr = run(["ip", "-4", "-o", "addr", "show", "dev", iface], capture=True, check=False)
    out = rr.stdout.strip()
    if not out:
        return "manual"
    if " dynamic " in out or "scope global dynamic" in out:
        return "dhcp"
    return "static-ish"


def generate_interfaces(ifaces: Iterable[str]) -> str:
    lines: List[str] = []
    lines.append("# /etc/network/interfaces")
    lines.append("# Generated by daifupdown (dumbass-tree)")
    lines.append("#")
    lines.append("# Notes:")
    lines.append("# - This generator assumes DHCP for most interfaces.")
    lines.append("# - For static addressing, edit the stanza manually.")
    lines.append("")
    lines.append("auto lo")
    lines.append("iface lo inet loopback")
    lines.append("")
    for iface in ifaces:
        method = _guess_iface_method(iface)
        if method == "dhcp":
            lines.append(f"auto {iface}")
            lines.append(f"iface {iface} inet dhcp")
            lines.append("")
        else:
            # leave as manual so it doesn't break things
            lines.append(f"# {iface} looks {method}. Configure manually if needed:")
            lines.append(f"# auto {iface}")
            lines.append(f"# iface {iface} inet static")
            lines.append(f"#     address 192.168.1.10/24")
            lines.append(f"#     gateway 192.168.1.1")
            lines.append("")
    return "\n".join(lines).rstrip() + "\n"


def cmd_plan(_: argparse.Namespace) -> None:
    print("daifupdown plan\n")
    yml = _list_netplan_yaml()
    if yml:
        print("Netplan YAML:")
        for f in yml:
            print(f"  - {f}")
    else:
        print("Netplan YAML: (none found)")

    print("\nServices:")
    for svc in ("systemd-networkd", "NetworkManager", "systemd-resolved"):
        print(f"  - {svc}: {_systemctl_active(svc)}")

    # resolv.conf wiring
    if os.path.exists("/etc/resolv.conf"):
        if os.path.islink("/etc/resolv.conf"):
            print(f"\n/etc/resolv.conf -> {os.readlink('/etc/resolv.conf')} (realpath: {os.path.realpath('/etc/resolv.conf')})")
        else:
            print("\n/etc/resolv.conf is a regular file")
    else:
        print("\n/etc/resolv.conf missing")

    print("\nInterfaces (ip -br addr):")
    print(_sh(["ip", "-br", "addr"]))

    print("\nRecommended 'least breakage' approach:")
    print("  1) Install ifupdown: sudo apt install ifupdown")
    print("  2) Generate /etc/network/interfaces from live system:")
    print("       sudo daifupdown generate --write --yes")
    print("  3) Disable netplan config by moving /etc/netplan/*.yaml aside (backup).")
    print("  4) Decide who manages Wi-Fi:")
    print("       - keep NetworkManager for Wi-Fi, and let ifupdown manage wired")
    print("       - OR disable NetworkManager entirely (more work for Wi-Fi)")
    print("  5) Reboot and validate.")
    print("\nRollback idea:")
    print("  - Put the YAML files back into /etc/netplan/ and run: sudo netplan apply")
    print("  - Remove/disable ifupdown if needed.")


def cmd_generate(args: argparse.Namespace) -> None:
    ifaces = _iface_candidates()
    txt = generate_interfaces(ifaces)
    if args.write:
        require_root()
        confirm_two_tier_or_exit(
            yes=args.yes,
            dry_run=args.dry_run,
            prompt="Write /etc/network/interfaces (backup existing first)",
            reason="A bad interfaces file can cut your networking at next boot.",
            alternatives=[
                "Run 'daifupdown generate' without --write to review first.",
                "Do this from a local console or ensure out-of-band access.",
            ],
            typed="YES WRITE /etc/network/interfaces",
        )
        if not args.dry_run:
            # backup
            ts = _dt.datetime.now().strftime("%Y%m%d-%H%M%S")
            backup_dir = pathlib.Path(f"/root/dumbass-tree-backups/ifupdown-{ts}")
            backup_dir.mkdir(parents=True, exist_ok=True)
            for p in ("/etc/network/interfaces",):
                if os.path.exists(p):
                    run(["cp", "-a", p, str(backup_dir)+"/"], check=False)
            pathlib.Path("/etc/network").mkdir(parents=True, exist_ok=True)
            pathlib.Path("/etc/network/interfaces").write_text(txt)
            info(f"wrote /etc/network/interfaces (backup in {backup_dir})")
        else:
            info("(dry-run) would write /etc/network/interfaces")
    else:
        print(txt)


def cmd_disable_netplan(args: argparse.Namespace) -> None:
    require_root()
    yml = _list_netplan_yaml()
    if not yml:
        info("no netplan YAML files found (nothing to do)")
        return

    confirm_two_tier_or_exit(
        yes=args.yes,
        dry_run=args.dry_run,
        prompt="Move /etc/netplan/*.yaml aside (disable netplan config)",
        reason="Without netplan, systemd-networkd/NetworkManager may not configure interfaces at boot.",
        alternatives=[
            "Generate /etc/network/interfaces first (daifupdown generate --write).",
            "Have a rollback plan: move the YAML files back and run 'netplan apply'.",
        ],
        typed="YES DISABLE NETPLAN",
    )

    ts = _dt.datetime.now().strftime("%Y%m%d-%H%M%S")
    dst = pathlib.Path(f"/etc/netplan/dumbass-disabled-{ts}")
    if not args.dry_run:
        dst.mkdir(parents=True, exist_ok=True)
    for f in yml:
        base = os.path.basename(f)
        run(["mv", f, str(dst / base)], dry_run=args.dry_run, verbose=args.verbose)
    info(f"moved {len(yml)} YAML files to {dst}")
    print("\nNext step: reboot. If you lose networking, rollback from console:")
    print(f"  sudo mv {dst}/*.yaml /etc/netplan/")
    print("  sudo netplan apply")


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="daifupdown", description=__doc__)
    p.add_argument("-v", "--verbose", action="count", default=0)
    p.add_argument("--dry-run", action="store_true", help="print commands, change nothing")

    sub = p.add_subparsers(dest="cmd", required=True)

    s = sub.add_parser("plan", help="inspect current netplan/NM/networkd/resolved situation")
    s.set_defaults(func=cmd_plan)

    s = sub.add_parser("generate", help="generate /etc/network/interfaces from live interfaces")
    s.add_argument("--write", action="store_true", help="write /etc/network/interfaces (with backups + warnings)")
    s.add_argument("--yes", action="store_true")
    s.set_defaults(func=cmd_generate)

    s = sub.add_parser("disable-netplan", help="move /etc/netplan/*.yaml aside (disable netplan config)")
    s.add_argument("--yes", action="store_true")
    s.set_defaults(func=cmd_disable_netplan)

    return p


def main(argv: list[str]) -> int:
    p = build_parser()
    args = p.parse_args(argv)
    args.func(args)
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
