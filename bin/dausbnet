#!/usr/bin/env python3
"""dausbnet - dumbass-friendly USB networking helper (Linux).

This is for the situations where you plug in:
- a USB ethernet dongle
- a phone in USB tethering mode
- a random USB LTE modem / RNDIS gadget
...and Linux creates an interface but you still somehow have *no* internet.

Goals:
- show what USB network interfaces exist
- bring an interface up
- (try to) get DHCP the least-annoying way available
- optionally generate a small systemd-networkd config for USB DHCP

This does NOT replace NetworkManager/systemd-networkd. It just gives you
a predictable set of commands that work without a GUI.
"""

from __future__ import annotations

import argparse
import os
import re
import shutil
import sys
from pathlib import Path
from typing import Iterable

_THIS = Path(__file__).resolve()
sys.path.insert(0, str(_THIS.parent))

from dumbasslib import confirm_or_exit, die, info, require_cmd, require_root, run, warn  # noqa: E402


def _have(cmd: str) -> bool:
    return shutil.which(cmd) is not None


def _sysfs_iface_path(iface: str) -> Path:
    return Path("/sys/class/net") / iface


def _is_usb_iface_heuristic(iface: str) -> bool:
    p = _sysfs_iface_path(iface) / "device"
    if not p.exists():
        return False
    real = os.path.realpath(p)
    # Heuristic: USB devices usually have /usbX/ in their sysfs path.
    return "/usb" in real


def _is_usb_iface(iface: str) -> bool:
    # Prefer udev properties if available (more accurate).
    if _have("udevadm"):
        rr = run(
            ["udevadm", "info", "-q", "property", "-p", str(_sysfs_iface_path(iface))],
            capture=True,
            check=False,
            dry_run=False,
            verbose=0,
        )
        props = rr.stdout.splitlines()
        for line in props:
            if line.strip() == "ID_BUS=usb":
                return True
            if line.strip().startswith("ID_USB_DRIVER="):
                return True
    return _is_usb_iface_heuristic(iface)


def usb_ifaces() -> list[str]:
    ifaces = []
    for name in os.listdir("/sys/class/net"):
        if name == "lo":
            continue
        if _is_usb_iface(name):
            ifaces.append(name)
    return sorted(ifaces)


def _pick_manager() -> str:
    """Roughly guess what manages networking."""
    # If nmcli exists and NM is running -> nm
    if _have("nmcli") and _have("systemctl"):
        rr = run(["systemctl", "is-active", "NetworkManager"], capture=True, check=False, dry_run=False)
        if rr.returncode == 0 and rr.stdout.strip() == "active":
            return "nm"
    # If networkd running -> networkd
    if _have("systemctl"):
        rr = run(["systemctl", "is-active", "systemd-networkd"], capture=True, check=False, dry_run=False)
        if rr.returncode == 0 and rr.stdout.strip() == "active":
            return "networkd"
    return "unknown"


def _ip_brief(iface: str) -> str:
    rr = run(["ip", "-brief", "addr", "show", "dev", iface], capture=True, check=False, dry_run=False)
    return rr.stdout.strip() or "(no output)"


def cmd_status(args: argparse.Namespace) -> None:
    require_cmd("ip")
    ifaces = usb_ifaces()
    mgr = _pick_manager()

    if not ifaces:
        warn("No USB network interfaces detected.")
        warn("If you expected one: check dmesg, lsusb, and that the device is actually USB ethernet/tethering.")
        return

    info(f"USB network interfaces (manager guess: {mgr}):")
    for iface in ifaces:
        print(f"- {iface}: {_ip_brief(iface)}")
        if _have("ethtool"):
            rr = run(["ethtool", "-i", iface], capture=True, check=False, dry_run=False)
            m = re.search(r"^driver:\s*(\S+)", rr.stdout, re.M)
            if m:
                print(f"    driver: {m.group(1)}")
        if _have("nmcli") and mgr == "nm":
            rr = run(
                ["nmcli", "-t", "-f", "DEVICE,TYPE,STATE,CONNECTION", "dev"],
                capture=True,
                check=False,
                dry_run=False,
            )
            for line in rr.stdout.splitlines():
                # DEVICE:TYPE:STATE:CONNECTION
                parts = line.split(":")
                if parts and parts[0] == iface:
                    state = parts[2] if len(parts) > 2 else "?"
                    con = parts[3] if len(parts) > 3 else "?"
                    print(f"    NetworkManager: {state} ({con})")
        if _have("networkctl") and mgr == "networkd":
            rr = run(["networkctl", "status", iface, "--no-pager"], capture=True, check=False, dry_run=False)
            # Print just a few useful lines
            lines = [ln.rstrip() for ln in rr.stdout.splitlines() if ln.strip()]
            for ln in lines[:8]:
                print(f"    {ln}")


def _dhcp_via_nm(iface: str, dry_run: bool, verbose: int) -> None:
    # NM often already auto-creates a connection, but 'dev connect' is the
    # "do the obvious thing" hammer.
    run(["nmcli", "device", "connect", iface], dry_run=dry_run, verbose=verbose)


def _dhcp_via_networkd(iface: str, dry_run: bool, verbose: int) -> None:
    # Ask networkd to re-apply config. If there is no matching .network file
    # nothing will happen; we'll fall back to a DHCP client.
    if _have("networkctl"):
        run(["networkctl", "reconfigure", iface], dry_run=dry_run, verbose=verbose, check=False)


def _dhcp_via_client(iface: str, dry_run: bool, verbose: int) -> None:
    # Fallback: run a DHCP client directly.
    if _have("dhclient"):
        run(["dhclient", "-v", iface], dry_run=dry_run, verbose=verbose)
        return
    if _have("udhcpc"):
        # -n: exit if no lease, -q: quiet-ish
        run(["udhcpc", "-i", iface, "-n", "-q"], dry_run=dry_run, verbose=verbose)
        return
    if _have("dhcpcd"):
        run(["dhcpcd", "-4", iface], dry_run=dry_run, verbose=verbose)
        return
    die("No DHCP client found (need dhclient, udhcpc, or dhcpcd), and no network manager handled it.")


def cmd_up(args: argparse.Namespace) -> None:
    require_root()
    require_cmd("ip")
    run(["ip", "link", "set", "dev", args.iface, "up"], dry_run=args.dry_run, verbose=args.verbose)


def cmd_down(args: argparse.Namespace) -> None:
    require_root()
    require_cmd("ip")
    run(["ip", "link", "set", "dev", args.iface, "down"], dry_run=args.dry_run, verbose=args.verbose)


def cmd_dhcp(args: argparse.Namespace) -> None:
    require_root()
    require_cmd("ip")
    # Bring link up first.
    run(["ip", "link", "set", "dev", args.iface, "up"], dry_run=args.dry_run, verbose=args.verbose)

    mgr = args.manager or _pick_manager()

    if mgr == "nm" and _have("nmcli"):
        _dhcp_via_nm(args.iface, args.dry_run, args.verbose)
    elif mgr == "networkd":
        _dhcp_via_networkd(args.iface, args.dry_run, args.verbose)
        # Even with networkd, running a DHCP client is often fine as a quick win.
        if args.force_client:
            _dhcp_via_client(args.iface, args.dry_run, args.verbose)
    else:
        _dhcp_via_client(args.iface, args.dry_run, args.verbose)

    # Show result
    if not args.dry_run:
        info(_ip_brief(args.iface))


def _networkd_file_text() -> str:
    return """# Generated by dausbnet
# This matches *USB* network links by udev path and enables DHCP.
#
# NOTE: Do not use this if NetworkManager is managing your network.
# Pick ONE network manager per interface, or you'll have a bad time.
#
# File location: /etc/systemd/network/99-dausbnet-usb-dhcp.network

[Match]
Path=usb-*
Type=ether

[Network]
DHCP=yes
"""


def cmd_persist_networkd(args: argparse.Namespace) -> None:
    require_root()
    target = Path("/etc/systemd/network/99-dausbnet-usb-dhcp.network")
    text = _networkd_file_text()

    reason = "this writes a persistent systemd-networkd config under /etc, and can conflict with NetworkManager"
    alternatives = (
        "If you use NetworkManager, prefer: nmcli device connect <iface>",
        "Print the config only: dausbnet persist --print",
    )

    if args.print_only:
        print(text)
        return

    confirm_or_exit(
        yes=args.yes,
        dry_run=args.dry_run,
        prompt=f"About to write: {target}",
        reason=reason,
        alternatives=alternatives,
        typed=None,
    )

    if args.dry_run:
        print(text)
        return

    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(text, encoding="utf-8")
    info(f"Wrote {target}")

    if args.apply:
        if _have("systemctl"):
            warn("Restarting systemd-networkd to apply config (this may briefly flap links).")
            run(["systemctl", "restart", "systemd-networkd"], dry_run=args.dry_run, verbose=args.verbose)
        else:
            warn("systemctl not found; please restart systemd-networkd manually.")


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="dausbnet", description="USB networking helper (DHCP + sanity checks)")
    p.add_argument("--dry-run", action="store_true", help="Print actions, do not execute")
    p.add_argument("-v", "--verbose", action="count", default=0, help="Verbose output")
    p.add_argument("--yes", action="store_true", help="Skip confirmation prompts where applicable")

    sub = p.add_subparsers(dest="cmd", required=True)

    sp = sub.add_parser("status", help="Show detected USB network interfaces")
    sp.set_defaults(func=cmd_status)

    sp = sub.add_parser("up", help="Bring interface up")
    sp.add_argument("iface")
    sp.set_defaults(func=cmd_up)

    sp = sub.add_parser("down", help="Bring interface down")
    sp.add_argument("iface")
    sp.set_defaults(func=cmd_down)

    sp = sub.add_parser("dhcp", help="Bring interface up and try DHCP")
    sp.add_argument("iface")
    sp.add_argument("--manager", choices=["nm", "networkd", "client"], help="Force a method")
    sp.add_argument(
        "--force-client",
        action="store_true",
        help="Even if networkd is running, run a DHCP client as fallback",
    )
    sp.set_defaults(func=cmd_dhcp)

    sp = sub.add_parser("persist", help="Generate or write a systemd-networkd DHCP config for USB ethernet")
    sp.add_argument("--print", dest="print_only", action="store_true", help="Print config to stdout (default)")
    sp.add_argument("--write", dest="print_only", action="store_false", help="Write config to /etc")
    sp.add_argument("--apply", action="store_true", help="Restart systemd-networkd after writing")
    sp.set_defaults(func=cmd_persist_networkd, print_only=True)

    return p


def main(argv: list[str]) -> None:
    args = build_parser().parse_args(argv)
    args.func(args)


if __name__ == "__main__":
    main(sys.argv[1:])
