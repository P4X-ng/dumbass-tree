#!/usr/bin/env python3
"""dabrowse - dumbass-friendly 'browser in the terminal' launcher.

This doesn't magically make the entire modern web pleasant in a TTY, but it helps you
stay in your terminal by picking the best available option:

- carbonyl (Chromium in terminal) if installed
- browsh (headless Firefox -> text) if installed
- w3m / links / lynx as fallbacks

Usage:
  dabrowse https://example.com
"""

from __future__ import annotations

import argparse
import shutil
import sys
from pathlib import Path

_THIS = Path(__file__).resolve()
sys.path.insert(0, str(_THIS.parent))

from dumbasslib import die, run  # noqa: E402


ENGINES = [
    ("carbonyl", ["carbonyl"]),
    ("browsh", ["browsh"]),
    ("w3m", ["w3m"]),
    ("links", ["links"]),
    ("elinks", ["elinks"]),
    ("lynx", ["lynx"]),
]


def _pick(engine: str) -> tuple[str, list[str]]:
    if engine != "auto":
        for name, argv0 in ENGINES:
            if name == engine:
                if shutil.which(argv0[0]):
                    return name, argv0
                die(f"requested engine not found in PATH: {engine}")
        die(f"unknown engine: {engine}")

    for name, argv0 in ENGINES:
        if shutil.which(argv0[0]):
            return name, argv0
    die("no terminal browser found (try installing: carbonyl, browsh, w3m, links, lynx)")


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="dabrowse", description="open URLs in a terminal browser")
    p.add_argument("--engine", default="auto", help="auto|carbonyl|browsh|w3m|links|elinks|lynx")
    p.add_argument("--dry-run", action="store_true", help="print command instead of running it")
    p.add_argument("-v", "--verbose", action="count", default=0, help="increase verbosity")
    p.add_argument("target", help="URL or path")
    return p


def main(argv: list[str] | None = None) -> None:
    args = build_parser().parse_args(argv)
    name, base = _pick(args.engine)
    cmd = [*base, args.target]
    run(cmd, dry_run=args.dry_run, verbose=args.verbose)


if __name__ == "__main__":
    main()
